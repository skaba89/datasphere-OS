# ═══════════════════════════════════════════════════
# DataSphere OS — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ═══════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_ici
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_ici

# ── Stripe ────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs Stripe (créez-les dans le dashboard Stripe)
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_AGENCY_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_EARLYBIRD=price_...

# Payment Links Stripe (alternatif aux Price IDs)
NEXT_PUBLIC_STRIPE_LINK_PRO_MONTHLY=https://buy.stripe.com/...
NEXT_PUBLIC_STRIPE_LINK_PRO_YEARLY=https://buy.stripe.com/...
NEXT_PUBLIC_STRIPE_LINK_AGENCY=https://buy.stripe.com/...
NEXT_PUBLIC_STRIPE_LINK_EARLYBIRD=https://buy.stripe.com/...

# ── IA Providers (côté serveur — JAMAIS exposées au client) ──
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# ── APIs Offres ────────────────────────────────────
ADZUNA_APP_ID=votre_app_id
ADZUNA_APP_KEY=votre_app_key
JOOBLE_API_KEY=votre_jooble_key

# ── App ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://datasphere-os.vercel.app
NEXT_PUBLIC_APP_NAME=DataSphere OS

# ── Email (Resend) ─────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@datasphere-os.fr
